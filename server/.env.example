# ═══════════════════════════════════════════════════
# StandByte server environment variables
# ═══════════════════════════════════════════════════
#
# Copy this file to ".env" and fill in your values.
# The .env file is gitignored so your credentials stay private.

# MongoDB connection string.
#
# Option A — Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/standbyte
#
# Option B — MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/standbyte?retryWrites=true&w=majority
#
# If unset, defaults to mongodb://localhost:27017/standbyte

MONGODB_URI=mongodb://localhost:27017/standbyte

# Server port (defaults to 4000)
PORT=4000
